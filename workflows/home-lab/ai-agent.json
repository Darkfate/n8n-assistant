              "value": "={{ $json.request_id }}"
            }
          ]
        }
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000009",
      "name": "Format Error Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [1560, 280]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {\n  status: $json.status,\n  message: $json.message,\n  action_taken: $json.action_taken,\n  entity: $json.entity || null,\n  request_id: $json.request_id\n} }}"
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000010",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [2000, 200]
    },
    {
      "parameters": {
        "url": "={{ $env.HOME_ASSISTANT_URL }}/api/states",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "homeAssistantApi",
        "options": {}
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000011",
      "name": "Get HA Entities",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 480],
      "credentials": {
        "homeAssistantApi": {
          "id": "2",
          "name": "Home Assistant API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Build entity context for AI from HA states\nconst entities = $input.first().json;\n\n// Group by domain and build context\nconst entityContext = {};\nconst domains = new Set();\n\nentities.forEach(entity => {\n  const [domain, name] = entity.entity_id.split('.');\n  domains.add(domain);\n  \n  if (!entityContext[domain]) {\n    entityContext[domain] = [];\n  }\n  \n  entityContext[domain].push({\n    entity_id: entity.entity_id,\n    state: entity.state,\n    friendly_name: entity.attributes?.friendly_name || name\n  });\n});\n\n// Build services context (common services per domain)\nconst servicesContext = {\n  light: ['turn_on', 'turn_off', 'toggle'],\n  climate: ['set_temperature', 'set_hvac_mode'],\n  cover: ['open_cover', 'close_cover', 'stop_cover'],\n  script: ['turn_on', 'reload'],\n  scene: ['turn_on'],\n  automation: ['turn_on', 'turn_off', 'trigger'],\n  switch: ['turn_on', 'turn_off', 'toggle'],\n  input_boolean: ['turn_on', 'turn_off', 'toggle']\n};\n\nreturn [{\n  json: {\n    entities_context: JSON.stringify(entityContext),\n    services_context: JSON.stringify(servicesContext),\n    available_domains: Array.from(domains),\n    entity_count: entities.length\n  }\n}];"
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000012",
      "name": "Build Entity Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 480]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "entities_context",
              "value": "={{ $('Build Entity Context').first().json.entities_context }}"
            },
            {
              "name": "services_context",
              "value": "={{ $('Build Entity Context').first().json.services_context }}"
            }
          ],
          "number": [
            {
              "name": "entity_count",
              "value": "={{ $('Build Entity Context').first().json.entity_count }}"
            }
          ]
        }
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000013",
      "name": "Merge Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [460, 380]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "error-handling",
