            },
            {
              "name": "action_taken",
              "value": "={{ $json.service }}"
            },
            {
              "name": "entity",
              "value": "={{ $json.entity_id }}"
            },
            {
              "name": "request_id",
              "value": "={{ $json.request_id }}"
            }
          ]
        }
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000008",
      "name": "Format Success Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [1780, 120]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "status",
