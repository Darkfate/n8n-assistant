            }
          ]
        }
      },
      "id": "b1c1e1c1-0000-4000-8000-000000000002",
      "name": "Extract Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [460, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "provider-config",
              "name": "ai_provider",
              "value": "=zai-glm",
